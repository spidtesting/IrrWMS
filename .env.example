# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
SKIP_ENV_VALIDATION=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=IrrWMS

# ─── Database ──────────────────────────────────────────────────────────────────
# Local (docker compose postgres on port 5433)
DATABASE_URL=postgresql://irrwms:irrwms_secret@localhost:5433/irrwms?schema=public
DIRECT_URL=postgresql://irrwms:irrwms_secret@localhost:5433/irrwms?schema=public

# Supabase — Session/Direct (port 5432) for migrate, seed, Railway, and Prisma CLI:
# DIRECT_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
#
# Supabase — Transaction pooler (port 6543) for serverless only (e.g. Vercel web):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# URL-encode password special chars: @ → %40, # → %23, : → %3A
# Validate: npm run db:check-url

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Railway/production: set BOTH names to the same value (Auth.js requires AUTH_SECRET).
NEXTAUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
AUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Socket Server ─────────────────────────────────────────────────────────────
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Worker / Cron ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
CRON_SECRET=generate-a-secure-cron-secret-min-16-chars
WORKER_ENABLED=true

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@irrwms.local

# ─── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Logging & Idempotency ───────────────────────────────────────────────────────
LOG_LEVEL=info
IDEMPOTENCY_TTL_SECONDS=86400

# ─── Production URLs (Railway) ─────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
# NEXTAUTH_URL=https://your-app.up.railway.app
# AUTH_URL=https://your-app.up.railway.app
# NEXT_PUBLIC_SOCKET_URL=https://your-socket.up.railway.app

# ─── Docker / local infra ──────────────────────────────────────────────────────
POSTGRES_USER=irrwms
POSTGRES_PASSWORD=irrwms_secret
POSTGRES_DB=irrwms
NGINX_PORT=80
NGINX_PORT_HTTP=80
APP_PORT=3000