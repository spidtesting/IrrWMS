# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
SKIP_ENV_VALIDATION=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=IrrWMS

# ─── Database (Supabase project: cakgsmzgdrsypwtmbmmw) ─────────────────────────
# Password: Supabase Dashboard → Settings → Database (NOT the anon/service_role JWT)
#
# Session pooler (5432) — app + Railway web/socket/worker:
# DATABASE_URL=postgresql://postgres.cakgsmzgdrsypwtmbmmw:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public
#
# Direct connection (5432) — Prisma migrate deploy / seed from CLI:
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.cakgsmzgdrsypwtmbmmw.supabase.co:5432/postgres?schema=public
#
# Transaction pooler (6543) — Vercel serverless only:
# DATABASE_URL=postgresql://postgres.cakgsmzgdrsypwtmbmmw:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Local Docker fallback:
DATABASE_URL=postgresql://irrwms:irrwms_secret@localhost:5433/irrwms?schema=public
DIRECT_URL=postgresql://irrwms:irrwms_secret@localhost:5433/irrwms?schema=public

# ─── Supabase project (optional — IrrWMS uses Prisma, not Supabase Auth) ───────
# NEXT_PUBLIC_SUPABASE_URL=https://cakgsmzgdrsypwtmbmmw.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
# AUTH_SECRET=same-as-NEXTAUTH_SECRET
# AUTH_URL=http://localhost:3000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Socket Server ─────────────────────────────────────────────────────────────
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Worker / Cron ─────────────────────────────────────────────────────────────
CRON_SECRET=generate-a-secure-cron-secret-min-16-chars
WORKER_ENABLED=true

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@irrwms.local

# ─── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Logging & Idempotency ───────────────────────────────────────────────────────
LOG_LEVEL=info
IDEMPOTENCY_TTL_SECONDS=86400

# ─── Production URLs (Railway) ─────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
# NEXTAUTH_URL=https://your-app.up.railway.app
# NEXT_PUBLIC_SOCKET_URL=https://your-socket.up.railway.app

# ─── Docker / Production ───────────────────────────────────────────────────────
POSTGRES_USER=irrwms
POSTGRES_PASSWORD=irrwms_secret
POSTGRES_DB=irrwms
NGINX_PORT=80
NGINX_PORT_HTTP=80
APP_PORT=3000
