# Copy these into Railway → each service → Variables
# Replace YOUR-WEB-DOMAIN and secrets before deploy

NODE_ENV=production

DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres?schema=public

NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=https://YOUR-WEB-DOMAIN.up.railway.app
AUTH_URL=https://YOUR-WEB-DOMAIN.up.railway.app
NEXT_PUBLIC_APP_URL=https://YOUR-WEB-DOMAIN.up.railway.app

# Web service only (set after socket is deployed):
NEXT_PUBLIC_SOCKET_URL=https://YOUR-SOCKET-DOMAIN.up.railway.app

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

WORKER_ENABLED=false
SOCKET_PORT=3001
CRON_SECRET=
LOG_LEVEL=info

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@irrwms.gov.lk
