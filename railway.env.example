# Copy these into Railway → each service → Variables
# Replace YOUR-WEB-DOMAIN and secrets before deploy

NODE_ENV=production

# Session mode, port 5432, URL-encoded password, sslmode=require
# Example project cakgsmzgdrsypwtmbmmw (aws-1-ap-southeast-2):
DATABASE_URL=postgresql://postgres.cakgsmzgdrsypwtmbmmw:URL_ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
DIRECT_URL=postgresql://postgres.cakgsmzgdrsypwtmbmmw:URL_ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
# Do NOT use port 6543 / pgbouncer=true on Railway — that is for serverless only.
# anon / service_role JWT keys are NOT used by IrrWMS (Prisma connects with the DB password above).

# Required — same 32+ char value for both (openssl rand -base64 32)
NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32
AUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32
# Public app URL (do not use 0.0.0.0). Optional if Railway sets RAILWAY_PUBLIC_DOMAIN:
NEXTAUTH_URL=https://YOUR-WEB-DOMAIN.up.railway.app
AUTH_URL=https://YOUR-WEB-DOMAIN.up.railway.app
NEXT_PUBLIC_APP_URL=https://YOUR-WEB-DOMAIN.up.railway.app

# Web service only (set after socket is deployed):
NEXT_PUBLIC_SOCKET_URL=https://YOUR-SOCKET-DOMAIN.up.railway.app

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

WORKER_ENABLED=false
SOCKET_PORT=3001
CRON_SECRET=
LOG_LEVEL=info

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@irrwms.gov.lk
