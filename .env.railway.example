# Copy these into Railway → Project → Shared Variables (or per-service where noted)
# Generate secrets: openssl rand -base64 32

NODE_ENV=production
SKIP_ENV_VALIDATION=false

# Set after first deploy (use Railway-generated *.railway.app URLs)
NEXTAUTH_URL=https://YOUR-WEB-SERVICE.up.railway.app
NEXT_PUBLIC_APP_URL=https://YOUR-WEB-SERVICE.up.railway.app
NEXT_PUBLIC_SOCKET_URL=https://YOUR-SOCKET-SERVICE.up.railway.app

NEXTAUTH_SECRET=CHANGE_ME_MIN_32_CHARS
CRON_SECRET=CHANGE_ME_MIN_16_CHARS
WORKER_ENABLED=true

# Linked automatically when you add Postgres + Redis plugins:
# DATABASE_URL=
# REDIS_URL=

LOG_LEVEL=warn
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional
# RESEND_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Web service build-time only (Dockerfile.web ARGs — set on "web" service):
# NEXT_PUBLIC_APP_NAME=IrrWMS
